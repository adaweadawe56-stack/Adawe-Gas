<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Seller Dashboard</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

body{
  background:#f5f5f5;
  font-family:Arial;
}

.login-box{
  max-width:400px;
  margin:80px auto;
  background:white;
  padding:30px;
  border-radius:15px;
  box-shadow:0 5px 20px rgba(0,0,0,0.1);
}

.dashboard{
  display:none;
  padding:20px;
}

.card-box{
  background:white;
  padding:20px;
  border-radius:15px;
  box-shadow:0 5px 15px rgba(0,0,0,0.08);
  margin-bottom:20px;
}

</style>

</head>
<body>

<!-- LOGIN -->

<div class="login-box" id="loginPage">

<h2 class="text-center mb-4">
Seller Login
</h2>

<input type="email"
       id="email"
       class="form-control mb-3"
       placeholder="Email">

<input type="password"
       id="password"
       class="form-control mb-3"
       placeholder="Password">

<button onclick="login()"
        class="btn btn-success w-100">
Login
</button>

<p id="loginError"
   class="text-danger mt-3 text-center">
</p>

</div>

<!-- DASHBOARD -->

<div class="dashboard" id="dashboard">

<div class="d-flex justify-content-between mb-4">

<h2>
Seller Dashboard
</h2>

<button onclick="logout()"
        class="btn btn-danger">
Logout
</button>

</div>

<div class="card-box">

<h4>
My Orders
</h4>

<table class="table">

<thead>

<tr>
<th>Name</th>
<th>Phone</th>
<th>Qty</th>
<th>Status</th>
<th>Actions</th>
</tr>

</thead>

<tbody id="ordersTable">

</tbody>

</table>

</div>

</div>

<script type="module">

import { initializeApp }
from "https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js";

import {
getFirestore,
collection,
query,
where,
onSnapshot,
doc,
updateDoc
}
from "https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore.js";

import {
getAuth,
signInWithEmailAndPassword,
signOut
}
from "https://www.gstatic.com/firebasejs/10.12.2/firebase-auth.js";

const firebaseConfig = {
  apiKey: "AIzaSyBVhASqIXG5OaVk1nr8c3hZ-_liTg1UIsw",
  authDomain: "adawe-gas-system-82187.firebaseapp.com",
  projectId: "adawe-gas-system-82187",
  storageBucket: "adawe-gas-system-82187.appspot.com",
  messagingSenderId: "644303663526",
  appId: "1:644303663526:web:bacf9e5db0d7787f705f67"
};

const app = initializeApp(firebaseConfig);

const db = getFirestore(app);

const auth = getAuth(app);

let sellerPhone = null;

/* LOGIN */

window.login = async function(){

  try{

    const email =
    document.getElementById("email").value;

    const password =
    document.getElementById("password").value;

    const userCredential =
    await signInWithEmailAndPassword(
      auth,
      email,
      password
    );

    sellerPhone =
    userCredential.user.phoneNumber;

    loginPage.style.display = "none";

    dashboard.style.display = "block";

    loadOrders();

  }catch(err){

    console.error(err);

    loginError.innerText =
    err.message;
  }

};

/* LOAD ORDERS */

function loadOrders(){

  const q = query(
    collection(db,"orders"),
    where("sellerPhone","==",sellerPhone)
  );

  onSnapshot(q,snap=>{

    ordersTable.innerHTML = "";

    snap.forEach(docSnap=>{

      const o = docSnap.data();

      ordersTable.innerHTML += `
      <tr>

      <td>${o.name || ""}</td>

      <td>${o.phone || ""}</td>

      <td>${o.quantity || ""}</td>

      <td>${o.status || ""}</td>

      <td>

      <button
      onclick="updateStatus('${docSnap.id}','Delivered')"
      class="btn btn-success btn-sm">

      Delivered

      </button>

      </td>

      </tr>`;
    });

  });

}

/* UPDATE STATUS */

window.updateStatus = async function(id,status){

  await updateDoc(doc(db,"orders",id),{
    status
  });

};

/* LOGOUT */

window.logout = async function(){

  await signOut(auth);

  location.reload();

};

</script>

</body>
</html>
